# Copy this file to .env and adjust as needed. .env is gitignored.

# UI/CLI language: en (default) or zh
EVA_LANG=en

# LLM endpoint (OpenAI-compatible /chat/completions API)
EVA_LLM_BASE_URL=http://localhost:8003/v1
EVA_LLM_MODEL=qwen3.6-27b-awq-int4
EVA_LLM_API_KEY=none

# Embedding model override (defaults depend on EVA_LANG: bge-small-zh for zh, multilingual MiniLM otherwise)
# EVA_EMBED_MODEL=paraphrase-multilingual-MiniLM-L12-v2
